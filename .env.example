# Arogyam Telemedicine Application - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from your Supabase Project Settings > API
# URL format: https://your-project-ref.supabase.co

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ⚠️ WARNING: Never use or commit the service_role key in your frontend!
# The service_role key bypasses Row Level Security and should only be used server-side.
# VITE_SUPABASE_SERVICE_ROLE_KEY=never_use_this_in_frontend

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Go to your Supabase Dashboard: https://app.supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the Project URL and paste it as VITE_SUPABASE_URL
# 5. Copy the anon/public key and paste it as VITE_SUPABASE_ANON_KEY
# 6. Rename this file from .env.example to .env
# 7. Never commit the .env file to version control (already in .gitignore)

# ============================================
# EXAMPLE (DO NOT USE THESE VALUES)
# ============================================
# VITE_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# OPTIONAL: OTHER SERVICES
# ============================================
# Add these if you integrate additional services

# Email Service (if using custom SMTP)
# VITE_SMTP_HOST=
# VITE_SMTP_PORT=
# VITE_SMTP_USER=
# VITE_SMTP_PASSWORD=

# Payment Gateway (if implementing payments)
# VITE_STRIPE_PUBLIC_KEY=
# VITE_RAZORPAY_KEY_ID=

# Analytics (if using)
# VITE_GOOGLE_ANALYTICS_ID=

# Video Call Service (if using third-party like Agora/Twilio)
# VITE_AGORA_APP_ID=
# VITE_TWILIO_ACCOUNT_SID=
# VITE_TWILIO_API_KEY=

# Maps Service (if showing clinic locations)
# VITE_GOOGLE_MAPS_API_KEY=

# ============================================
# NOTES
# ============================================
# - All VITE_ prefixed variables are exposed to the frontend
# - Store sensitive keys in server-side only (without VITE_ prefix)
# - For production, use environment variables in your hosting platform
# - Never commit real credentials to version control
# - Update these values for development, staging, and production environments
